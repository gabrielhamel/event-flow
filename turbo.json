{
  "$schema": "https://v2-9-4.turborepo.dev/schema.json",
  "ui": "stream",
  "envMode": "strict",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "MODE",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "NODE_ENV"
  ],
  "tasks": {
    "test": {
      "dependsOn": ["^test"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "ci": {
      "dependsOn": ["//#format:check", "test"]
    }
  }
}
