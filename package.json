{
  "name": "ddd-lab",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:check": "turbo run lint:check",
    "lint:fix": "turbo run lint:fix",
    "format:fix": "dprint fmt",
    "format:check": "dprint check",
    "type:check": "turbo run type:check",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "ci": "turbo run ci --affected"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dprint": "^0.53.2",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@swc/core",
      "canvas",
      "dprint",
      "esbuild",
      "prisma"
    ]
  },
  "volta": {
    "node": "25.8.1",
    "pnpm": "10.33.0"
  }
}
