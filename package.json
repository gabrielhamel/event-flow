{
  "name": "ddd-lab",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:check": "turbo run lint:check",
    "lint:fix": "turbo run lint:fix",
    "format:fix": "dprint fmt",
    "format:check": "dprint check",
    "type:check": "turbo run type:check",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "ci": "turbo run ci --affected"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "dprint": "^0.51.1",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "tsx": "^4.20.4",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "canvas",
      "dprint",
      "esbuild"
    ]
  },
  "volta": {
    "node": "24.13.1",
    "pnpm": "10.30.3"
  }
}
