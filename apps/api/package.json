{
  "name": "@repo/api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint:check": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "type:check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "dev": "tsx --env-file-if-exists=.env --tsconfig tsconfig.app.json --watch src/index.ts",
    "build": "tsc --build tsconfig.app.json"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "jiti": "^2.6.1"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "@hocuspocus/server": "^3.4.4",
    "better-auth": "^1.5.4",
    "express": "^5.2.1",
    "express-ws": "^5.0.2"
  }
}
