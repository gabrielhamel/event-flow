{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "paths": {
      "@repo/core/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "*.config.ts",
    "eslint.config.ts"
  ]
}
